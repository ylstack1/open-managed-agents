# Required for harness turns (any Anthropic-compatible API key).
ANTHROPIC_API_KEY=sk-...

# Optional: point at an Anthropic-compatible proxy. The SDK appends
# `/messages` to whatever you set, so include `/v1` (provider.ts will
# append /v1 automatically if missing — but being explicit is clearer).
# ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# Optional: extra HTTP headers comma-separated. Used when the proxy
# requires e.g. a sub-module gating header.
# ANTHROPIC_CUSTOM_HEADERS=X-Sub-Module: my-module

# Optional: override the listening port (host side). Defaults to 8787.
# OMA_PORT=8787

# Optional: switch the SQL backend from sqlite (default) to postgres. When
# set, DATABASE_URL takes precedence over DATABASE_PATH; both schemas are
# the same DDL (BIGINT timestamps work in both). Use a postgres:// URL.
# DATABASE_URL=postgres://oma:oma@postgres:5432/oma

# Auth secret. Required for prod — sessions are signed with it; sessions
# don't survive restart if missing. Generate one with:
#   openssl rand -hex 32
BETTER_AUTH_SECRET=

# Required: at-rest encryption key for credentials.auth and
# model_cards.api_key_cipher. The Cloudflare worker build refuses to start
# without it (and the Node self-host is moving the same direction).
# Generate with:
#   openssl rand -base64 32
PLATFORM_ROOT_SECRET=

# Public base URL — used for cookie domain + OAuth redirect URLs. Defaults
# to "*" trusted-origins if missing (only OK for local dev).
# PUBLIC_BASE_URL=https://oma.example.com

# Optional: bypass auth entirely. Every request becomes tenant_id="default".
# Use ONLY for local single-user demos. Production must leave this unset.
# AUTH_DISABLED=1

# Optional: Google OAuth. When both are set, /api/auth/sign-in/social/google
# becomes available.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Sandbox provider. Default is `subprocess` (LocalSubprocessSandbox — fast
# local dev, NO isolation). Production / untrusted agents should use one of
# the isolated backends:
#
#   subprocess (default) — host child_process. No isolation. Trusted dev.
#   daytona              — Daytona Cloud (managed Linux VM per session).
#                          Set DAYTONA_API_KEY (and optionally DAYTONA_API_URL,
#                          SANDBOX_IMAGE).
#   litebox              — BoxLite local micro-VM (Firecracker per box).
#                          Hardware isolation, no daemon. Optional:
#                          LITEBOX_MEMORY_MIB, LITEBOX_CPUS, SANDBOX_IMAGE.
#   e2b                  — E2B Firecracker SaaS. Set E2B_API_KEY.
#
# SANDBOX_PROVIDER=subprocess
# DAYTONA_API_KEY=
# DAYTONA_API_URL=
# E2B_API_KEY=
# SANDBOX_IMAGE=node:22-slim
# LITEBOX_MEMORY_MIB=512
# LITEBOX_CPUS=2

# Memory bucket config for remote sandboxes (daytona / e2b). When all four
# are set, those backends mount the bucket via s3fs at /mnt/_oma_storage
# and symlink per-store prefixes under /mnt/memory/<storeName>. Without
# them, mountMemoryStore on remote sandboxes throws — the operator must
# either provide an s3-compatible store or use the subprocess/litebox
# backends which can use the local LocalFsBlobStore directly.
#
# MEMORY_S3_ENDPOINT=https://s3.us-west-2.amazonaws.com
# MEMORY_S3_ACCESS_KEY=
# MEMORY_S3_SECRET_KEY=
# MEMORY_S3_BUCKET=oma-memory

# ─── Integrations (Linear / GitHub / Slack on self-host) ────────────────
# All three are optional. Only set the providers you intend to wire up.
# When PLATFORM_ROOT_SECRET is unset, the entire integrations write surface
# (OAuth callbacks, setup pages, webhooks, Linear MCP, GitHub refresh) is
# disabled — read-side CRUD still works against any pre-seeded rows.
#
# Public origin for the integrations gateway (OAuth redirect_uri + webhook
# URLs handed to Linear/GitHub/Slack). No trailing slash. When self-hosting
# behind a reverse proxy, set this to the externally-reachable URL.
# Defaults to PUBLIC_BASE_URL or http://localhost:8787.
# GATEWAY_ORIGIN=https://oma.example.com
#
# Internal token gating /github/internal/* (refresh-by-vault). Treat as a
# secret. Required for the session-create credential refresh path to work.
# Generate with: openssl rand -hex 32
# INTEGRATIONS_INTERNAL_TOKEN=
#
# Provider OAuth client credentials. Each provider's "create app" wizard
# emits the values; paste them here. CLIENT_SECRETs go through
# PLATFORM_ROOT_SECRET-derived AES-GCM at rest in the per-app row, but
# the wrangler-provided env values themselves are operator-owned.
# LINEAR_OAUTH_CLIENT_ID=
# LINEAR_OAUTH_CLIENT_SECRET=
# GITHUB_OAUTH_CLIENT_ID=
# GITHUB_OAUTH_CLIENT_SECRET=
# SLACK_OAUTH_CLIENT_ID=
# SLACK_OAUTH_CLIENT_SECRET=
# FEISHU_OAUTH_CLIENT_ID=
# FEISHU_OAUTH_CLIENT_SECRET=
# ASANA_OAUTH_CLIENT_ID=
# ASANA_OAUTH_CLIENT_SECRET=
# CLICKUP_OAUTH_CLIENT_ID=
# CLICKUP_OAUTH_CLIENT_SECRET=
