{
  "name": "open-managed-agents",
  "version": "0.1.0",
  "description": "Open-source meta-harness for AI agents — Anthropic Managed Agents API parity, runs on Cloudflare Workers or self-hosted Node.",
  "homepage": "https://openma.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/open-ma/open-managed-agents"
  },
  "bugs": {
    "url": "https://github.com/open-ma/open-managed-agents/issues"
  },
  "license": "Apache-2.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "wrangler dev -c apps/main/wrangler.jsonc -c apps/agent/wrangler.dev.jsonc",
    "dev:main": "wrangler dev -c apps/main/wrangler.jsonc",
    "dev:agent": "wrangler dev -c apps/agent/wrangler.dev.jsonc",
    "dev:console": "cd apps/console && npx vite",
    "build:console": "cd apps/console && npx vite build",
    "dev:docs": "pnpm --filter open-managed-agents-docs dev",
    "build:docs": "pnpm --filter open-managed-agents-docs build",
    "deploy:docs": "pnpm --filter open-managed-agents-docs deploy",
    "deploy": "./scripts/deploy.sh",
    "typecheck": "tsc --noEmit && pnpm run typecheck:node",
    "typecheck:node": "pnpm --filter @open-managed-agents/sandbox typecheck && pnpm --filter @open-managed-agents/main-node typecheck && pnpm --filter @open-managed-agents/oma-vault typecheck && pnpm --filter @open-managed-agents/cap typecheck",
    "test": "vitest run && pnpm run test:packages && pnpm run test:console",
    "test:packages": "pnpm --filter @open-managed-agents/session-runtime test && pnpm --filter @open-managed-agents/main-node test && pnpm --filter @open-managed-agents/cap test",
    "test:console": "pnpm --filter managed-agents-console test",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm -r --filter='@openma/*' build && changeset publish"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "0.95.1",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.31.0",
    "@cloudflare/vitest-pool-workers": "^0.14.7",
    "@cloudflare/workers-types": "^4.20250410.0",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "fflate": "^0.8.2",
    "jsonc-parser": "^3.3.1",
    "typescript": "^5.8.0",
    "vitest": "^4.1.3",
    "wrangler": "^4.83.0"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "3.0.69",
    "@ai-sdk/openai": "^3.0.53",
    "ai": "6.0.158",
    "better-auth": "^1.6.3",
    "drizzle-orm": "^0.45.2",
    "zod": "4.3.6"
  },
  "packageManager": "pnpm@11.0.8"
}
