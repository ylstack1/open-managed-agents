{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": "src",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@/registry/default/ui/*": ["./src/components/ui/*"],
      "@/registry/default/blocks/*": ["./src/components/blocks/*"],
      "@/registry/default/hooks/*": ["./src/hooks/*"],
      "@/registry/default/lib/*": ["./src/lib/*"]
    }
  },
  "include": ["src"]
}
