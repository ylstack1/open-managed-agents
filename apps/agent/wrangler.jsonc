{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "sandbox-default",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-13",
  "compatibility_flags": ["nodejs_compat"],

  // ─────────────────────────────────────────────────────────────────────
  // SELF-HOST BASELINE (sandbox/agent worker)
  // ─────────────────────────────────────────────────────────────────────
  // Top-level config = single-D1 self-host shape. Multi-shard prod
  // for openma.dev lives in env.production overlay below.
  // ─────────────────────────────────────────────────────────────────────

  "containers": [
    {
      "class_name": "Sandbox",
      "image": "./Dockerfile.sandbox",
      "instance_type": "standard-1",
      "max_instances": 50
    }
  ],

  "durable_objects": {
    "bindings": [
      { "name": "SESSION_DO", "class_name": "SessionDO" },
      { "name": "SANDBOX", "class_name": "Sandbox" },
      // Cross-script DO binding for RuntimeRoom. The class lives in the main
      // worker (apps/main/wrangler.jsonc), but DOs are namespace-level and
      // any worker in the account can bind the same class via `script_name`.
      // AcpProxyHarness uses this to attach to the daemon's RuntimeRoom
      // directly, no service-binding hop through main and no shared secret —
      // see apps/agent/src/harness/acp-proxy-loop.ts.
      { "name": "RUNTIME_ROOM", "class_name": "RuntimeRoom", "script_name": "managed-agents" }
    ]
  },

  "kv_namespaces": [
    { "binding": "CONFIG_KV", "id": "<set-by-setup-cf-sh>" }
  ],

  // D1 layout — single-D1 self-host baseline. Same auto-detection as
  // apps/main/wrangler.jsonc: when AUTH_DB_01 isn't bound, the shared
  // MemoryStoreService resolves every tenant to MAIN_DB.
  "d1_databases": [
    { "binding": "MAIN_DB", "database_name": "openma-auth", "database_id": "<set-by-setup-cf-sh>" }
  ],

  // Service bindings:
  //
  // - INTEGRATIONS: integrations gateway. Used by the outbound proxy to
  //   refresh short-lived upstream tokens (e.g. GitHub installation tokens,
  //   ~1hr TTL) on 401. The agent worker never sees provider secrets directly
  //   — it just asks the gateway "please refresh credential X" and the gateway
  //   does the App-JWT signing using its locally-held private key.
  //
  // - MAIN_MCP: WorkerEntrypoint RPC into the main worker for MCP forwarding
  //   (cloud agent path). Per-request the DO calls
  //   `env.MAIN_MCP.mcpForward({tenantId, sessionId, serverName, ...})` and
  //   the main worker (where vault credentials already live) does the cred
  //   lookup + token injection + upstream call. The agent's DO never holds
  //   plaintext credentials — mirrors Anthropic Managed Agents' "credential
  //   proxy outside the harness" design. See apps/main/src/index.ts:McpProxyRpc
  //   for the entrypoint, packages/binding-mcp-transport for the AI-SDK
  //   transport adapter.
  "services": [
    { "binding": "INTEGRATIONS", "service": "managed-agents-integrations" },
    { "binding": "MAIN_MCP", "service": "managed-agents", "entrypoint": "McpProxyRpc" }
  ],

  // Workers AI for generating embeddings
  "ai": { "binding": "AI" },

  // Resolved bucket names per env — sandbox.ts FUSE mode mounts via the
  // S3 API which takes the actual bucket name (not the binding name).
  // CLOUDFLARE_ACCOUNT_ID is required by sandbox SDK createBackup() to
  // mint R2 presigned URLs for the squashfs upload (production mode).
  // setup-cf.sh fills in the account id (or self-hoster sets it manually).
  "vars": {
    "MEMORY_BUCKET_NAME": "managed-agents-memory",
    "WORKSPACE_BUCKET_NAME": "managed-agents-workspace",
    "BACKUP_BUCKET_NAME": "managed-agents-backups",
    "CLOUDFLARE_ACCOUNT_ID": "<set-by-setup-cf-sh>"
  },

  "r2_buckets": [
    { "binding": "WORKSPACE_BUCKET", "bucket_name": "managed-agents-workspace" },
    { "binding": "FILES_BUCKET", "bucket_name": "managed-agents-files" },
    // Required by @cloudflare/sandbox createBackup/restoreBackup. Holds
    // the squashfs archives the BaseSnapshotStrategy persists per env.
    // The SDK looks for the binding by the literal name BACKUP_BUCKET.
    { "binding": "BACKUP_BUCKET", "bucket_name": "managed-agents-backups" },
    // Memory store content. Mounted into the sandbox per attached store via
    // sandbox.mountBucket(<bucket-name>, "/mnt/memory/<store_name>",
    //   { endpoint+credentials+provider:"r2", prefix: "/<store_id>/", readOnly })
    // Agent reads/writes via standard file tools; writes propagate to R2 then
    // feed the apps/main MEMORY queue consumer for D1 audit.
    { "binding": "MEMORY_BUCKET", "bucket_name": "managed-agents-memory" }
  ],

  "browser": { "binding": "BROWSER" },

  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["SessionDO", "Sandbox"]
    }
  ],

  "limits": { "cpu_ms": 300000 },
  "observability": { "enabled": true },

  "analytics_engine_datasets": [
    { "binding": "ANALYTICS", "dataset": "oma_events" }
  ],

  // ─────────────────────────────────────────────────────────────────────
  // ENVIRONMENT OVERLAYS (hosted)
  // ─────────────────────────────────────────────────────────────────────
  "env": {
    "production": {
      "name": "sandbox-default",
      "containers": [
        {
          "class_name": "Sandbox",
          "image": "./Dockerfile.sandbox",
          "instance_type": "standard-1",
          "max_instances": 50
        }
      ],
      "durable_objects": {
        "bindings": [
          { "name": "SESSION_DO", "class_name": "SessionDO" },
          { "name": "SANDBOX", "class_name": "Sandbox" },
          { "name": "RUNTIME_ROOM", "class_name": "RuntimeRoom", "script_name": "managed-agents" }
        ]
      },
      "kv_namespaces": [
        { "binding": "CONFIG_KV", "id": "5e49bdaec1884f5989037c86ece7b462" }
      ],
      "d1_databases": [
        { "binding": "MAIN_DB",    "database_name": "openma-auth",          "database_id": "dbb5f01c-7016-4157-945d-f8ff9fbda967" },
        { "binding": "ROUTER_DB",  "database_name": "openma-router",        "database_id": "6ddad512-7976-4912-8003-7746ba1e4cb6" },
        { "binding": "AUTH_DB_00", "database_name": "openma-auth",          "database_id": "dbb5f01c-7016-4157-945d-f8ff9fbda967" },
        { "binding": "AUTH_DB_01", "database_name": "openma-auth-shard-01", "database_id": "37a3138c-8d1e-4258-8a0d-e0da511b0175" },
        { "binding": "AUTH_DB_02", "database_name": "openma-auth-shard-02", "database_id": "254c56dc-2a99-4266-87ae-9ff46355eb75" },
        { "binding": "AUTH_DB_03", "database_name": "openma-auth-shard-03", "database_id": "a4f72551-7ce7-4da3-a33e-f4abb00bb86f" }
      ],
      "services": [
        { "binding": "INTEGRATIONS", "service": "managed-agents-integrations" },
        { "binding": "MAIN_MCP", "service": "managed-agents", "entrypoint": "McpProxyRpc" }
      ],
      "ai": { "binding": "AI" },
      "vars": {
        "MEMORY_BUCKET_NAME": "managed-agents-memory",
        "WORKSPACE_BUCKET_NAME": "managed-agents-workspace",
        "BACKUP_BUCKET_NAME": "managed-agents-backups",
        "CLOUDFLARE_ACCOUNT_ID": "44af79e51582ca20c9003eb926540242"
      },
      "r2_buckets": [
        { "binding": "WORKSPACE_BUCKET", "bucket_name": "managed-agents-workspace" },
        { "binding": "FILES_BUCKET", "bucket_name": "managed-agents-files" },
        { "binding": "BACKUP_BUCKET", "bucket_name": "managed-agents-backups" },
        { "binding": "MEMORY_BUCKET", "bucket_name": "managed-agents-memory" }
      ],
      "browser": { "binding": "BROWSER" },
      "limits": { "cpu_ms": 300000 },
      "observability": { "enabled": true },
      "analytics_engine_datasets": [
        { "binding": "ANALYTICS", "dataset": "oma_events" }
      ]
    },
    "staging": {
      "name": "sandbox-default-staging",
      "containers": [
        {
          "class_name": "Sandbox",
          "image": "./Dockerfile.sandbox",
          "instance_type": "standard-1",
          "max_instances": 50
        }
      ],
      "services": [
        { "binding": "INTEGRATIONS", "service": "managed-agents-integrations-staging" },
        { "binding": "MAIN_MCP", "service": "managed-agents-staging", "entrypoint": "McpProxyRpc" }
      ],
      // Cross-script DO binding to staging RuntimeRoom (lives in
      // managed-agents-staging). Same shape as prod above.
      "durable_objects": {
        "bindings": [
          { "name": "SESSION_DO", "class_name": "SessionDO" },
          { "name": "SANDBOX", "class_name": "Sandbox" },
          { "name": "RUNTIME_ROOM", "class_name": "RuntimeRoom", "script_name": "managed-agents-staging" }
        ]
      },
      "kv_namespaces": [
        { "binding": "CONFIG_KV", "id": "f91ddab8abe64941bd3ef398b0c187a7" }
      ],
      "d1_databases": [
        { "binding": "MAIN_DB",    "database_name": "openma-auth-staging",          "database_id": "aff5dbb7-36f9-46b7-b82f-4513e5603ac6" },
        { "binding": "ROUTER_DB",  "database_name": "openma-router-staging",        "database_id": "c238a338-9b6e-40c5-aaaa-48d4fe6dc63d" },
        { "binding": "AUTH_DB_00", "database_name": "openma-auth-staging",          "database_id": "aff5dbb7-36f9-46b7-b82f-4513e5603ac6" },
        { "binding": "AUTH_DB_01", "database_name": "openma-auth-shard-01-staging", "database_id": "fe6a34d1-cd8a-48a1-bff1-29032026d006" },
        { "binding": "AUTH_DB_02", "database_name": "openma-auth-shard-02-staging", "database_id": "8636a018-8ac6-48c2-ae95-2f70919c8aab" },
        { "binding": "AUTH_DB_03", "database_name": "openma-auth-shard-03-staging", "database_id": "8ce8f17d-7527-4a5a-b097-ce73251be55a" }
      ],
      "ai": { "binding": "AI" },
      "vars": {
        "MEMORY_BUCKET_NAME": "managed-agents-memory-staging",
        "WORKSPACE_BUCKET_NAME": "managed-agents-workspace",
        "BACKUP_BUCKET_NAME": "managed-agents-backups",
        "CLOUDFLARE_ACCOUNT_ID": "44af79e51582ca20c9003eb926540242"
      },
      "r2_buckets": [
        { "binding": "WORKSPACE_BUCKET", "bucket_name": "managed-agents-workspace" },
        { "binding": "FILES_BUCKET", "bucket_name": "managed-agents-files" },
        { "binding": "BACKUP_BUCKET", "bucket_name": "managed-agents-backups" },
        { "binding": "MEMORY_BUCKET", "bucket_name": "managed-agents-memory-staging" }
      ],
      "browser": { "binding": "BROWSER" },
      "limits": { "cpu_ms": 300000 },
      "observability": { "enabled": true },
      "analytics_engine_datasets": [
        { "binding": "ANALYTICS", "dataset": "oma_events_staging" }
      ]
    }
  }
}
