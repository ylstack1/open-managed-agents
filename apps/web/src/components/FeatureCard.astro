---
/**
 * "Why X" feature card. Used 3× on the homepage in the credibility
 * grid. Title + body via slot so callers can include `<code>` runs and
 * inline links without props gymnastics.
 *
 * Round-3 audit flagged the original 3-card grid as "bordering on the
 * identical-card-grid anti-pattern" — accepting an optional `accent`
 * prop lets callers visually differentiate one card (e.g. the canonical
 * one) by tinting its border to brand.
 */
export interface Props {
  title: string;
  /** When set, swaps neutral border for brand color. Use sparingly —
   *  highlights one card in a row. */
  accent?: boolean;
}

const { title, accent } = Astro.props;
---

<div
  class:list={[
    "rounded-lg p-6 transition-colors duration-150",
    accent
      ? "border-2 border-[var(--color-brand)]"
      : "border border-[var(--color-border)] hover:border-[var(--color-border-strong)]",
  ]}
>
  <h3 class="font-semibold text-lg mb-2">{title}</h3>
  <p class="text-[var(--color-fg-muted)] text-sm leading-relaxed">
    <slot />
  </p>
</div>
